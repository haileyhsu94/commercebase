# Excluded from docker build context.
# Critical: exclude vendor/ so the build's composer install (--no-dev) result
# isn't overwritten by local dev vendor/ that contains pail/pint/phpunit etc.

# Backend
backend/vendor/
backend/node_modules/
backend/storage/logs/*
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
backend/bootstrap/cache/*
backend/.env
backend/.env.local
backend/.env.testing
backend/.phpunit.result.cache
backend/.phpactor.json
backend/tests/

# Frontend (not bundled in image — Vercel handles)
frontend/

# Worker
dailyclicks-worker/node_modules/
dailyclicks-worker/dist/
dailyclicks-worker/.dailyclicks-session.json
dailyclicks-worker/.explore-out/

# General
.git/
.github/
.idea/
.vscode/
*.log
*.md
!README.md

# Docker (the build references these by COPY anyway, but exclude the rest)
docker-compose.yml
